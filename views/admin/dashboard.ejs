                { section: 'Portfolio Item 3', key: 'portfolio-item-3-title', label: 'Item 3: Title', type: 'text', limit: 40 },
                
                { section: 'Portfolio Item 4', key: 'portfolio-item-4-img', label: 'Item 4: Image URL', type: 'text' },
                { section: 'Portfolio Item 4', key: 'portfolio-item-4-cat', label: 'Item 4: Category', type: 'select', options: ['all', 'vid', 'img'] },
                { section: 'Portfolio Item 4', key: 'portfolio-item-4-title', label: 'Item 4: Title', type: 'text', limit: 40 },
                
                { section: 'Portfolio Item 5', key: 'portfolio-item-5-img', label: 'Item 5: Image URL', type: 'text' },
                { section: 'Portfolio Item 5', key: 'portfolio-item-5-cat', label: 'Item 5: Category', type: 'select', options: ['all', 'vid', 'img'] },
                { section: 'Portfolio Item 5', key: 'portfolio-item-5-title', label: 'Item 5: Title', type: 'text', limit: 40 },
                
                { section: 'Portfolio Item 6', key: 'portfolio-item-6-img', label: 'Item 6: Image URL', type: 'text' },
                { section: 'Portfolio Item 6', key: 'portfolio-item-6-cat', label: 'Item 6: Category', type: 'select', options: ['all', 'vid', 'img'] },
                { section: 'Portfolio Item 6', key: 'portfolio-item-6-title', label: 'Item 6: Title', type: 'text', limit: 40 }
            ]
        };

        async function selectPage(page) {
            currentPage = page;
            
            // Update UI
            document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
            const btn = document.getElementById('btn-' + page);
            if (btn) btn.classList.add('active');
            
            document.getElementById('currentPageTitle').innerText = page.replace('-', ' ').toUpperCase() + ' PAGE';
            
            // Hide the 'ADD SECTION' button if we aren't managing blog-premium
            const addSectionBtn = document.getElementById('addSectionBtn');
            if (page === 'blog-premium') {
                addSectionBtn.classList.remove('hidden');
            } else {
                addSectionBtn.classList.add('hidden');
            }
            
            loadContent();
        }



        async function loadContent() {
            const grid = document.getElementById('contentGrid');
            grid.innerHTML = '<div class="animate-pulse flex flex-col gap-4"><div class="h-12 bg-gray-200 rounded-xl w-1/4"></div><div class="h-32 bg-gray-200 rounded-xl"></div></div>';
            
            try {
                const response = await fetch(`/api/content/${currentPage}`);
                pageContents = await response.json();
                
                renderFields();
            } catch (err) {
                console.error(err);
                grid.innerHTML = '<p class="text-red-500">Error loading content.</p>';
            }
        }

        function renderFields() {
            const grid = document.getElementById('contentGrid');
            grid.innerHTML = '';
            
            const fields = pageSchema[currentPage] || [];
            
            if (fields.length === 0) {
                grid.innerHTML = '<div class="text-center py-20 border-2 border-dashed border-black/5 rounded-[40px] text-gray-400">Select a page from the sidebar to manage its content.</div>';
                return;
            }

            let currentSection = '';
            let sectionContainer = null;

            fields.forEach(field => {
                if (field.section !== currentSection) {
                    currentSection = field.section;
                    const sectionHeader = document.createElement('div');
                    sectionHeader.className = 'col-span-full pt-8 pb-4';
                    sectionHeader.innerHTML = `<h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray-400">${currentSection}</h3>`;
                    grid.appendChild(sectionHeader);
                    
                    if (currentSection === 'Service Cards') {
                        sectionContainer = document.createElement('div');
                        sectionContainer.className = 'grid grid-cols-1 md:grid-cols-2 gap-6 col-span-full';
                        grid.appendChild(sectionContainer);
                    } else {
                        sectionContainer = grid;
                    }
                }

                const value = pageContents[field.key] || '';
                const card = document.createElement('div');
                card.className = 'glass rounded-[32px] p-8 space-y-4 hover:shadow-lg transition-all duration-500 bg-white';
                
                const limit = field.limit || 500;
                let inputHtml = '';
                
                if (field.type === 'textarea') {
                    inputHtml = `<textarea id="input-${field.key}" maxlength="${limit}" oninput="updateCounter('${field.key}', ${limit})" class="w-full bg-transparent border border-black/5 rounded-2xl p-4 text-sm focus:outline-none focus:border-black/20 min-h-[120px]" placeholder="Enter ${field.label}...">${value}</textarea>`;
                } else if (field.type === 'select') {
                    const optionsHtml = field.options.map(opt => `<option value="${opt}" ${value === opt ? 'selected' : ''}>${opt.toUpperCase()}</option>`).join('');
                    inputHtml = `<select id="input-${field.key}" class="w-full bg-transparent border border-black/5 rounded-2xl p-4 text-sm focus:outline-none focus:border-black/20 cursor-pointer appearance-none">
                        ${optionsHtml}
                    </select>`;
                } else {
                    inputHtml = `<input type="text" id="input-${field.key}" maxlength="${limit}" oninput="updateCounter('${field.key}', ${limit})" value="${value}" class="w-full bg-transparent border border-black/5 rounded-2xl p-4 text-sm focus:outline-none focus:border-black/20" placeholder="Enter ${field.label}...">`;
                }

                card.innerHTML = `
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center">
                                <span class="material-symbols-outlined text-gray-400 text-lg">edit_note</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">${field.label}</h4>
                                <div class="flex items-center gap-2">
                                    <span class="text-[9px] font-mono text-gray-400 uppercase tracking-widest">${field.key}</span>
                                    ${field.type !== 'select' ? `<span id="counter-${field.key}" class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">${value.length}/${limit}</span>` : ''}
                                </div>
                            </div>
                        </div>
                        <button onclick="saveField('${field.key}')" id="btn-save-${field.key}" class="group flex items-center gap-2 text-xs font-black bg-black text-white px-5 py-2.5 rounded-full hover:scale-105 transition-all">
                            <span>SAVE</span>
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </button>
                    </div>
                    <div class="pt-2">
                        ${inputHtml}
                    </div>
                `;
                sectionContainer.appendChild(card);
            });
            
            if (currentPage === 'blog-premium') {
                loadDynamicArticles(grid);
            }
        }

        function updateCounter(key, limit) {
            const val = document.getElementById('input-' + key).value;
            const counter = document.getElementById('counter-' + key);
            counter.innerText = val.length + '/' + limit;
            if (val.length >= limit) {
                counter.classList.add('text-red-500');
            } else {
                counter.classList.remove('text-red-500');
            }
        }

        async function saveField(key) {
            const value = document.getElementById('input-' + key).value;
            const btn = document.getElementById('btn-save-' + key);
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined">sync</span>';
            btn.disabled = true;
            
            try {
                const response = await fetch('/api/content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ page: currentPage, key, value })
                });
                
                const result = await response.json();
                if (result.success) {
                    showToast('Field "' + key + '" updated successfully');
                    btn.innerHTML = '<span class="material-symbols-outlined">done</span> SAVED';
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }, 2000);
                } else {
                    alert('Error: ' + result.error);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert('Failed to save.');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMessage').innerText = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        async function loadDynamicArticles(grid) {
            const sectionHeader = document.createElement('div');
            sectionHeader.className = 'col-span-full pt-12 pb-4 flex justify-between items-end';
            sectionHeader.innerHTML = `
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray-400">PUBLISHED ARTICLES</h3>
            `;
            grid.appendChild(sectionHeader);

            const articlesContainer = document.createElement('div');
            articlesContainer.className = 'grid grid-cols-1 md:grid-cols-2 gap-6 col-span-full';
            articlesContainer.id = 'articlesContainer';
            grid.appendChild(articlesContainer);

            try {
                const response = await fetch('/api/articles');
                const articles = await response.json();
                
                if (articles.length === 0) {
                    articlesContainer.innerHTML = '<p class="text-gray-400 text-sm col-span-full">No articles published yet.</p>';
                } else {
                    articles.forEach(article => {
                        const card = document.createElement('div');
                        card.className = 'glass rounded-[32px] p-6 space-y-4 bg-white hover:shadow-lg transition-all relative';
                        card.innerHTML = `
                            <button onclick="deleteArticle('${article._id}')" class="absolute top-6 right-6 text-red-500 hover:text-red-700 transition-colors">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                            <span class="text-[9px] font-bold text-black uppercase tracking-widest bg-gray-100 px-3 py-1 rounded-full">${article.category}</span>
                            <h4 class="font-bold text-lg leading-tight pr-8">${article.title}</h4>
                            <p class="text-xs text-gray-500 line-clamp-2">${article.summary}</p>
                            <img src="${article.imageUrl}" alt="" class="w-full h-32 object-cover rounded-xl mt-4">
                        `;
                        articlesContainer.appendChild(card);
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteArticle(id) {
            if (!confirm('Are you sure you want to delete this article?')) return;
            try {
                const response = await fetch('/api/articles/' + id, { method: 'DELETE' });
                const result = await response.json();
                if (result.success) {
                    showToast('Article deleted');
                    renderFields(); // Re-render to refresh list
                }
            } catch (err) {
                console.error(err);
            }
        }

        function openArticleModal() {
            document.getElementById('articleModal').classList.remove('hidden');
            document.getElementById('articleModal').classList.add('flex');
        }

        function closeArticleModal() {
            document.getElementById('articleModal').classList.add('hidden');
            document.getElementById('articleModal').classList.remove('flex');
            document.getElementById('newArticleForm').reset();
        }

        async function publishArticle(e) {
            e.preventDefault();
            const btn = document.getElementById('btnPublishArticle');
            btn.innerHTML = 'PUBLISHING...';
            btn.disabled = true;

            const data = {
                title: document.getElementById('art-title').value,
                summary: document.getElementById('art-summary').value,
                category: document.getElementById('art-category').value,
                imageUrl: document.getElementById('art-img').value
            };

            try {
                const response = await fetch('/api/articles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) {
                    showToast('Article published');
                    closeArticleModal();
                    renderFields();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (err) {
                console.error(err);
            } finally {
                btn.innerHTML = 'PUBLISH';
                btn.disabled = false;
            }
        }


        // Initial Load
        selectPage('services');
    </script>
</body>
</html>
