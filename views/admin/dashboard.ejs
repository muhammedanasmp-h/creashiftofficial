<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | CREASHIFT Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(0,0,0,0.05); }
        .sidebar-item.active { background: black; color: white; }
    </style>
</head>
<body class="bg-[#fcf8fb] text-[#1b1b1d] min-h-screen flex">
    <!-- Sidebar -->
    <aside class="w-72 border-r border-black/5 p-8 flex flex-col h-screen sticky top-0 bg-white">
        <div class="mb-12">
            <h1 class="text-xl font-black tracking-tighter">CREASHIFT</h1>
            <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Admin Dashboard</p>
        </div>
        
        <nav class="flex-grow space-y-2">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Pages</p>
            <button onclick="selectPage('services')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-gray-100 flex items-center justify-between group active" id="btn-services">
                Services
                <span class="material-symbols-outlined text-lg opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
            </button>
            <button onclick="selectPage('portfolio')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-gray-100 flex items-center justify-between group" id="btn-portfolio">
                Portfolio
                <span class="material-symbols-outlined text-lg opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
            </button>
            <button onclick="selectPage('blog-premium')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-gray-100 flex items-center justify-between group" id="btn-blog-premium">
                Blog / Editorial
                <span class="material-symbols-outlined text-lg opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
            </button>
            <button onclick="selectPage('contact')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-sm font-medium transition-all hover:bg-gray-100 flex items-center justify-between group" id="btn-contact">
                Contact
                <span class="material-symbols-outlined text-lg opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
            </button>
            
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest pt-6 mb-4">Service Details</p>
            <button onclick="selectPage('service-seo')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-seo">SEO Architecture</button>
            <button onclick="selectPage('service-social')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-social">Social Ecosystems</button>
            <button onclick="selectPage('service-web')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-web">Web Engineering</button>
            <button onclick="selectPage('service-ads')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-ads">Paid Ads</button>
            <button onclick="selectPage('service-design')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-design">Design & Identity</button>
            <button onclick="selectPage('service-video')" class="sidebar-item w-full text-left px-4 py-3 rounded-xl text-xs font-medium transition-all hover:bg-gray-100" id="btn-service-video">Video Production</button>
        </nav>
        
        <div class="pt-8 border-t border-black/5 mt-auto">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-10 rounded-full bg-black text-white flex items-center justify-center font-bold">
                    <%= user.displayName.charAt(0) %>
                </div>
                <div>
                    <p class="text-sm font-bold truncate max-w-[140px]"><%= user.displayName %></p>
                    <p class="text-[10px] text-gray-400 uppercase tracking-widest">Administrator</p>
                </div>
            </div>
            <a href="/logout" class="flex items-center gap-2 text-xs font-bold text-red-500 hover:opacity-70 transition-opacity">
                <span class="material-symbols-outlined text-lg">logout</span>
                SIGN OUT
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-grow p-12 overflow-y-auto">
        <header class="flex justify-between items-center mb-12">
            <div>
                <h2 id="currentPageTitle" class="text-4xl font-black uppercase tracking-tighter">SERVICES PAGE</h2>
                <p class="text-gray-500 text-sm mt-1">Manage content and service cards for this page.</p>
            </div>
            <button onclick="addNewField()" class="flex items-center gap-2 bg-black text-white px-6 py-3 rounded-full text-sm font-bold hover:scale-105 transition-all">
                <span class="material-symbols-outlined">add</span>
                ADD SECTION
            </button>
        </header>

        <!-- Content Grid -->
        <div id="contentGrid" class="grid grid-cols-1 gap-6">
            <!-- Fields will be loaded here -->
            <div class="animate-pulse flex flex-col gap-4">
                <div class="h-12 bg-gray-200 rounded-xl w-1/4"></div>
                <div class="h-32 bg-gray-200 rounded-xl"></div>
            </div>
        </div>
    </main>

    <!-- Edit Modal (Simplified for inline editing) -->
    <div id="toast" class="fixed bottom-8 right-8 bg-black text-white px-6 py-4 rounded-2xl shadow-2xl translate-y-20 opacity-0 transition-all duration-500 flex items-center gap-3 z-50">
        <span class="material-symbols-outlined text-green-400">check_circle</span>
        <span id="toastMessage">Changes saved successfully</span>
    </div>

    <script>
        let currentPage = 'services';
        let pageContents = {};

        // Define the "Premium Schema" - Every field on every page is mapped here
        const pageSchema = {
            'services': [
                { section: 'Hero Section', key: 'services-label', label: 'Page Subtitle', type: 'text', limit: 30 },
                { section: 'Hero Section', key: 'services-headline', label: 'Main Headline', type: 'text', limit: 40 },
                { section: 'Hero Section', key: 'services-subtext', label: 'Hero Subtext', type: 'textarea', limit: 250 },
                
                { section: 'Service Cards', key: 'services-card-seo-title', label: 'Card 1: SEO Architecture (Title)', type: 'text', limit: 25 },
                { section: 'Service Cards', key: 'services-card-seo-desc', label: 'Card 1: Description', type: 'textarea', limit: 120 },
                
                { section: 'Service Cards', key: 'services-card-social-title', label: 'Card 2: Social Ecosystems (Title)', type: 'text', limit: 25 },
                { section: 'Service Cards', key: 'services-card-social-desc', label: 'Card 2: Description', type: 'textarea', limit: 120 },
                
                { section: 'Service Cards', key: 'services-card-web-title', label: 'Card 3: Web Engineering (Title)', type: 'text', limit: 25 },
                { section: 'Service Cards', key: 'services-card-web-desc', label: 'Card 3: Description', type: 'textarea', limit: 120 },
                
                { section: 'Service Cards', key: 'services-card-ads-title', label: 'Card 4: Paid Ads (Title)', type: 'text', limit: 25 },
                { section: 'Service Cards', key: 'services-card-ads-desc', label: 'Card 4: Description', type: 'textarea', limit: 120 },
                
                { section: 'Service Cards', key: 'services-card-design-title', label: 'Card 5: Design & Identity (Title Only)', type: 'text', limit: 25 },
                { section: 'Service Cards', key: 'services-card-video-title', label: 'Card 6: Video Production (Title Only)', type: 'text', limit: 25 }
            ],
            'service-seo': [
                { key: 'seo-headline', label: 'Main Headline', type: 'text' },
                { key: 'seo-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'seo-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'seo-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'seo-card-1-title', label: 'Feature 1: Title', type: 'text' },
                { key: 'seo-card-1-desc', label: 'Feature 1: Description', type: 'textarea' },
                { key: 'seo-card-2-title', label: 'Feature 2: Title', type: 'text' },
                { key: 'seo-card-2-desc', label: 'Feature 2: Description', type: 'textarea' }
            ],
            'service-social': [
                { key: 'social-headline', label: 'Main Headline', type: 'text' },
                { key: 'social-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'social-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'social-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'social-card-1-title', label: 'Feature 1: Title', type: 'text' },
                { key: 'social-card-1-desc', label: 'Feature 1: Description', type: 'textarea' },
                { key: 'social-card-2-title', label: 'Feature 2: Title', type: 'text' },
                { key: 'social-card-2-desc', label: 'Feature 2: Description', type: 'textarea' }
            ],
            'service-web': [
                { key: 'web-headline', label: 'Main Headline', type: 'text' },
                { key: 'web-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'web-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'web-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'web-card-1-title', label: 'Feature 1: Title', type: 'text' },
                { key: 'web-card-1-desc', label: 'Feature 1: Description', type: 'textarea' },
                { key: 'web-card-2-title', label: 'Feature 2: Title', type: 'text' },
                { key: 'web-card-2-desc', label: 'Feature 2: Description', type: 'textarea' },
                { key: 'web-card-3-title', label: 'Feature 3: Title', type: 'text' },
                { key: 'web-card-3-desc', label: 'Feature 3: Description', type: 'textarea' }
            ],
            'service-ads': [
                { key: 'ads-headline', label: 'Main Headline', type: 'text' },
                { key: 'ads-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'ads-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'ads-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'ads-metric-1-value', label: 'Metric 1: Value (e.g. 350%)', type: 'text' },
                { key: 'ads-metric-1-label', label: 'Metric 1: Label', type: 'text' },
                { key: 'ads-metric-2-value', label: 'Metric 2: Value', type: 'text' },
                { key: 'ads-metric-2-label', label: 'Metric 2: Label', type: 'text' }
            ],
            'service-design': [
                { key: 'design-headline', label: 'Main Headline', type: 'text' },
                { key: 'design-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'design-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'design-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'design-card-1-title', label: 'Feature 1: Title', type: 'text' },
                { key: 'design-card-1-desc', label: 'Feature 1: Description', type: 'textarea' },
                { key: 'design-card-2-title', label: 'Feature 2: Title', type: 'text' },
                { key: 'design-card-2-desc', label: 'Feature 2: Description', type: 'textarea' }
            ],
            'service-video': [
                { key: 'video-headline', label: 'Main Headline', type: 'text' },
                { key: 'video-intro', label: 'Intro Paragraph', type: 'textarea' },
                { key: 'video-sub-headline', label: 'Sub-Section: Headline', type: 'text' },
                { key: 'video-sub-intro', label: 'Sub-Section: Intro', type: 'textarea' },
                { key: 'video-card-1-title', label: 'Feature 1: Title', type: 'text' },
                { key: 'video-card-1-desc', label: 'Feature 1: Description', type: 'textarea' },
                { key: 'video-card-2-title', label: 'Feature 2: Title', type: 'text' },
                { key: 'video-card-2-desc', label: 'Feature 2: Description', type: 'textarea' }
            ],
            'blog-premium': [
                { key: 'blog-hero-label', label: 'Hero Subtitle (e.g. Editorial Archive)', type: 'text' },
                { key: 'blog-hero-headline', label: 'Main Headline', type: 'text' },
                { key: 'blog-hero-subtext', label: 'Hero Description', type: 'textarea' },
                { key: 'blog-featured-title', label: 'Featured Article: Title', type: 'text' },
                { key: 'blog-featured-desc', label: 'Featured Article: Summary', type: 'textarea' }
            ],
            'portfolio': [
                { key: 'portfolio-headline', label: 'Main Headline', type: 'text' },
                { key: 'portfolio-subtext', label: 'Hero Description', type: 'textarea' },
                { key: 'portfolio-item-1-img', label: 'Item 1: Image URL', type: 'text' },
                { key: 'portfolio-item-1-cat', label: 'Item 1: Category', type: 'text' },
                { key: 'portfolio-item-1-title', label: 'Item 1: Title', type: 'text' },
                { key: 'portfolio-item-2-img', label: 'Item 2: Image URL', type: 'text' },
                { key: 'portfolio-item-2-cat', label: 'Item 2: Category', type: 'text' },
                { key: 'portfolio-item-2-title', label: 'Item 2: Title', type: 'text' },
                { key: 'portfolio-item-3-img', label: 'Item 3: Image URL', type: 'text' },
                { key: 'portfolio-item-3-cat', label: 'Item 3: Category', type: 'text' },
                { key: 'portfolio-item-3-title', label: 'Item 3: Title', type: 'text' },
                { key: 'portfolio-item-4-img', label: 'Item 4: Image URL', type: 'text' },
                { key: 'portfolio-item-4-cat', label: 'Item 4: Category', type: 'text' },
                { key: 'portfolio-item-4-title', label: 'Item 4: Title', type: 'text' },
                { key: 'portfolio-item-5-img', label: 'Item 5: Image URL', type: 'text' },
                { key: 'portfolio-item-5-cat', label: 'Item 5: Category', type: 'text' },
                { key: 'portfolio-item-5-title', label: 'Item 5: Title', type: 'text' },
                { key: 'portfolio-item-6-img', label: 'Item 6: Image URL', type: 'text' },
                { key: 'portfolio-item-6-cat', label: 'Item 6: Category', type: 'text' },
                { key: 'portfolio-item-6-title', label: 'Item 6: Title', type: 'text' }
            ]
        };

        async function selectPage(page) {
            currentPage = page;
            
            // Update UI
            document.querySelectorAll('.sidebar-item').forEach(el => el.classList.remove('active'));
            const btn = document.getElementById('btn-' + page);
            if (btn) btn.classList.add('active');
            
            document.getElementById('currentPageTitle').innerText = page.replace('-', ' ').toUpperCase() + ' PAGE';
            
            loadContent();
        }

        async function loadContent() {
            const grid = document.getElementById('contentGrid');
            grid.innerHTML = '<div class="animate-pulse flex flex-col gap-4"><div class="h-12 bg-gray-200 rounded-xl w-1/4"></div><div class="h-32 bg-gray-200 rounded-xl"></div></div>';
            
            try {
                const response = await fetch(`/api/content/${currentPage}`);
                pageContents = await response.json();
                
                renderFields();
            } catch (err) {
                console.error(err);
                grid.innerHTML = '<p class="text-red-500">Error loading content.</p>';
            }
        }

        function renderFields() {
            const grid = document.getElementById('contentGrid');
            grid.innerHTML = '';
            
            const fields = pageSchema[currentPage] || [];
            
            if (fields.length === 0) {
                grid.innerHTML = '<div class="text-center py-20 border-2 border-dashed border-black/5 rounded-[40px] text-gray-400">Select a page from the sidebar to manage its content.</div>';
                return;
            }

            let currentSection = '';
            let sectionContainer = null;

            fields.forEach(field => {
                if (field.section !== currentSection) {
                    currentSection = field.section;
                    const sectionHeader = document.createElement('div');
                    sectionHeader.className = 'col-span-full pt-8 pb-4';
                    sectionHeader.innerHTML = `<h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray-400">${currentSection}</h3>`;
                    grid.appendChild(sectionHeader);
                    
                    if (currentSection === 'Service Cards') {
                        sectionContainer = document.createElement('div');
                        sectionContainer.className = 'grid grid-cols-1 md:grid-cols-2 gap-6 col-span-full';
                        grid.appendChild(sectionContainer);
                    } else {
                        sectionContainer = grid;
                    }
                }

                const value = pageContents[field.key] || '';
                const card = document.createElement('div');
                card.className = 'glass rounded-[32px] p-8 space-y-4 hover:shadow-lg transition-all duration-500 bg-white';
                
                const limit = field.limit || 500;
                const inputHtml = field.type === 'textarea' 
                    ? `<textarea id="input-${field.key}" maxlength="${limit}" oninput="updateCounter('${field.key}', ${limit})" class="w-full bg-transparent border border-black/5 rounded-2xl p-4 text-sm focus:outline-none focus:border-black/20 min-h-[120px]" placeholder="Enter ${field.label}...">${value}</textarea>`
                    : `<input type="text" id="input-${field.key}" maxlength="${limit}" oninput="updateCounter('${field.key}', ${limit})" value="${value}" class="w-full bg-transparent border border-black/5 rounded-2xl p-4 text-sm focus:outline-none focus:border-black/20" placeholder="Enter ${field.label}...">`;

                card.innerHTML = `
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center">
                                <span class="material-symbols-outlined text-gray-400 text-lg">edit_note</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">${field.label}</h4>
                                <div class="flex items-center gap-2">
                                    <span class="text-[9px] font-mono text-gray-400 uppercase tracking-widest">${field.key}</span>
                                    <span id="counter-${field.key}" class="text-[9px] font-bold text-gray-300 uppercase tracking-widest">${value.length}/${limit}</span>
                                </div>
                            </div>
                        </div>
                        <button onclick="saveField('${field.key}')" id="btn-save-${field.key}" class="group flex items-center gap-2 text-xs font-black bg-black text-white px-5 py-2.5 rounded-full hover:scale-105 transition-all">
                            <span>SAVE</span>
                            <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </button>
                    </div>
                    <div class="pt-2">
                        ${inputHtml}
                    </div>
                `;
                sectionContainer.appendChild(card);
            });
        }

        function updateCounter(key, limit) {
            const val = document.getElementById('input-' + key).value;
            const counter = document.getElementById('counter-' + key);
            counter.innerText = val.length + '/' + limit;
            if (val.length >= limit) {
                counter.classList.add('text-red-500');
            } else {
                counter.classList.remove('text-red-500');
            }
        }

        async function saveField(key) {
            const value = document.getElementById('input-' + key).value;
            const btn = document.getElementById('btn-save-' + key);
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined">sync</span>';
            btn.disabled = true;
            
            try {
                const response = await fetch('/api/content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ page: currentPage, key, value })
                });
                
                const result = await response.json();
                if (result.success) {
                    showToast('Field "' + key + '" updated successfully');
                    btn.innerHTML = '<span class="material-symbols-outlined">done</span> SAVED';
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }, 2000);
                } else {
                    alert('Error: ' + result.error);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert('Failed to save.');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMessage').innerText = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // Initial Load
        selectPage('services');
    </script>
</body>
</html>
