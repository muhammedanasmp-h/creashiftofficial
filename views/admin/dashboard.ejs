                <p class="text-gray-500 text-sm mt-1">Manage content and service cards for this page.</p>
            </div>
            <button onclick="openArticleModal()" id="addSectionBtn" class="hidden flex items-center gap-2 bg-black text-white px-6 py-3 rounded-full text-sm font-bold hover:scale-105 transition-all">
                <span class="material-symbols-outlined">add</span>
                PUBLISH ARTICLE
            </button>
        </header>

        <!-- Content Grid -->
        <div id="contentGrid" class="grid grid-cols-1 gap-6">
            <!-- Fields will be loaded here -->
            <div class="animate-pulse flex flex-col gap-4">
                <div class="h-12 bg-gray-200 rounded-xl w-1/4"></div>
                <div class="h-32 bg-gray-200 rounded-xl"></div>
            </div>
        </div>
    </main>

    <!-- Edit Modal (Simplified for inline editing) -->
    <div id="toast" class="fixed bottom-8 right-8 bg-black text-white px-6 py-4 rounded-2xl shadow-2xl translate-y-20 opacity-0 transition-all duration-500 flex items-center gap-3 z-50">
        <span class="material-symbols-outlined text-green-400">check_circle</span>
        <span id="toastMessage">Changes saved successfully</span>
    </div>

    <!-- Article Publish Modal -->
    <div id="articleModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-[32px] p-8 relative">
            <button onclick="closeArticleModal()" class="absolute top-6 right-6 text-gray-400 hover:text-black">
                <span class="material-symbols-outlined">close</span>
            </button>
            <h2 class="text-2xl font-black uppercase tracking-tighter mb-6">Publish Article</h2>
            <form id="newArticleForm" onsubmit="publishArticle(event)" class="space-y-4">
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Category</label>
                    <select id="art-category" required class="w-full bg-transparent border border-black/5 rounded-xl p-4 text-sm focus:outline-none focus:border-black/20">
                        <option value="strategy">STRATEGY</option>
                        <option value="design">DESIGN</option>
                        <option value="technology">TECHNOLOGY</option>
                        <option value="case-studies">CASE STUDIES</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Image URL</label>
                    <input type="text" id="art-img" required class="w-full bg-transparent border border-black/5 rounded-xl p-4 text-sm focus:outline-none focus:border-black/20" placeholder="https://...">
                </div>
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Title</label>
                    <input type="text" id="art-title" required class="w-full bg-transparent border border-black/5 rounded-xl p-4 text-sm focus:outline-none focus:border-black/20" placeholder="Article title">
                </div>
                <div>
                    <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Summary</label>
                    <textarea id="art-summary" required class="w-full bg-transparent border border-black/5 rounded-xl p-4 text-sm focus:outline-none focus:border-black/20 min-h-[100px]" placeholder="Short description..."></textarea>
                </div>
                <button type="submit" id="btnPublishArticle" class="w-full bg-black text-white font-bold py-4 rounded-xl hover:scale-[1.02] transition-transform text-sm tracking-widest mt-4">PUBLISH</button>
            </form>
        </div>
    </div>

